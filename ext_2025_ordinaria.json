   "svg_tarjeta": "<svg viewBox='0 0 90 60' fill='none' stroke='#a78bfa' stroke-width='3'><path d='M10 34h70'/><path d='M20 34v-10M34 34v-10M48 34v-10M62 34v-10'/></svg>",
